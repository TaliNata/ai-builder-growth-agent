APP_NAME=Marketplace Growth Agent
ENV=development
DEBUG=true
API_PORT=8000
LOG_LEVEL=INFO

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=growth_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/growth_agent

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

USE_CELERY=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

GITHUB_TOKEN=
GITHUB_SEARCH_QUERY=agent OR langgraph OR crewai OR autogen OR "ai agent"
DISCOVERY_MAX_USERS=20
RECENT_ACTIVITY_DAYS=30

OUTREACH_MODE=demo
DEMO_RECIPIENT_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
REPLY_SYNC_FOLDER=INBOX

FOLLOW_UP_DELAY_DAYS=3
MAX_FOLLOW_UPS=2

ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# Telegram Bot (для telegram_bot.py — запускается отдельно)
# Токен от @BotFather, chat id от @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

